# Hatch Skill - ERC-721 NFT

## Purpose

Guide the user through designing and writing an ERC-721 NFT contract on Base. Covers fixed supply, open edition, reveal mechanics, royalties, and soulbound variants.

## Questions to ask before writing code

If not already answered in the spec:

1. Fixed supply or open edition?
2. What is the max supply? (if fixed)
3. Mint price? Free, ETH, or ERC-20 token?
4. Public mint, allowlist, or both?
5. Instant reveal or delayed reveal?
6. On-chain or off-chain metadata? (IPFS / Arweave for off-chain)
7. Royalties on secondary sales? What percentage? (EIP-2981)
8. Soulbound? (non-transferable)
9. Does it need staking or utility beyond the NFT itself?

## Standard implementation

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.24;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Enumerable.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721URIStorage.sol";
import "@openzeppelin/contracts/token/common/ERC2981.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract [CollectionName] is ERC721, ERC721Enumerable, ERC2981, Ownable, ReentrancyGuard {
    uint256 public constant MAX_SUPPLY = [supply];
    uint256 public constant MINT_PRICE = [price] ether;
    uint256 private _nextTokenId;

    string private _baseTokenURI;
    bool public revealed;
    string public hiddenURI;

    error MaxSupplyReached();
    error InsufficientPayment();
    error WithdrawFailed();

    constructor(address initialOwner, string memory baseURI)
        ERC721("[Collection Name]", "[SYMBOL]")
        Ownable(initialOwner)
    {
        _baseTokenURI = baseURI;
        // Set royalty: 5% to owner
        _setDefaultRoyalty(initialOwner, 500);
    }

    function mint(uint256 quantity) external payable nonReentrant {
        if (_nextTokenId + quantity > MAX_SUPPLY) revert MaxSupplyReached();
        if (msg.value < MINT_PRICE * quantity) revert InsufficientPayment();

        for (uint256 i = 0; i < quantity; i++) {
            _safeMint(msg.sender, _nextTokenId++);
        }
    }

    function reveal(string memory baseURI) external onlyOwner {
        revealed = true;
        _baseTokenURI = baseURI;
    }

    function tokenURI(uint256 tokenId) public view override(ERC721, ERC721URIStorage) returns (string memory) {
        if (!revealed) return hiddenURI;
        return super.tokenURI(tokenId);
    }

    function withdraw() external onlyOwner {
        (bool success, ) = owner().call{value: address(this).balance}("");
        if (!success) revert WithdrawFailed();
    }

    // Required overrides
    function _update(address to, uint256 tokenId, address auth)
        internal override(ERC721, ERC721Enumerable) returns (address)
    {
        return super._update(to, tokenId, auth);
    }

    function _increaseBalance(address account, uint128 value)
        internal override(ERC721, ERC721Enumerable)
    {
        super._increaseBalance(account, value);
    }

    function supportsInterface(bytes4 interfaceId)
        public view override(ERC721, ERC721Enumerable, ERC2981)
        returns (bool)
    {
        return super.supportsInterface(interfaceId);
    }
}
```

## Allowlist variant (Merkle tree)

```solidity
import "@openzeppelin/contracts/utils/cryptography/MerkleProof.sol";

bytes32 public merkleRoot;

function allowlistMint(bytes32[] calldata proof, uint256 quantity)
    external payable nonReentrant
{
    bytes32 leaf = keccak256(abi.encodePacked(msg.sender));
    require(MerkleProof.verify(proof, merkleRoot, leaf), "Not on allowlist");
    // proceed with mint
}

function setMerkleRoot(bytes32 root) external onlyOwner {
    merkleRoot = root;
}
```

Generate merkle tree off-chain with `merkletreejs` + `keccak256`.

## Soulbound variant

Override transfer to block all transfers except minting:

```solidity
function _update(address to, uint256 tokenId, address auth)
    internal override returns (address)
{
    address from = _ownerOf(tokenId);
    require(from == address(0), "Soulbound: non-transferable");
    return super._update(to, tokenId, auth);
}
```

## On-chain metadata variant

```solidity
import "@openzeppelin/contracts/utils/Base64.sol";

function tokenURI(uint256 tokenId) public view override returns (string memory) {
    string memory json = Base64.encode(bytes(string(abi.encodePacked(
        '{"name":"[Collection] #', Strings.toString(tokenId),
        '","description":"[Description]",',
        '"image":"data:image/svg+xml;base64,', _generateSVG(tokenId), '"}'
    ))));
    return string(abi.encodePacked("data:application/json;base64,", json));
}
```

## Audit flags specific to ERC-721

- `_safeMint` can reenter if minting to a contract -- ReentrancyGuard required
- No max per wallet check = one wallet can sweep entire supply
- `withdraw()` should use call not transfer (2300 gas limit)
- Royalties are not enforced on-chain -- marketplaces can bypass EIP-2981

